# Database - for Docker deployment, use /app/data path (volume-mounted)
DATABASE_URL="file:./dev.db"

# Admin password for /admin/login (required)
ADMIN_PASSWORD="change-me"

# JWT secret for admin session cookie (required, use a long random string)
# Generate with: openssl rand -hex 32
JWT_SECRET="change-me-in-production"

# Set to "true" to auto-seed sample data on first startup (Docker only)
SEED_ON_STARTUP="false"

# Override container port mapping
PORT=3000
